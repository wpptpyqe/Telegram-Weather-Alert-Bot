import urllib.request #웹 요청을 보내기 위한 라이브러리
import json #JSON 데이터 처리를 위한 라이브러리
import datetime #날짜 및 시간 처리를 위한 라이브러리
import asyncio #비동기 처리를 위한 라이브러리

from telegram import Bot # Telegram Bot 기능을 사용하기 위한 라이브러리

telegram_id = '8602676478' #Telegram 채팅방 ID 입력

my_token = '8680769702:AAFVD4D0avElpB6tEJwPrwEnUBY2XbDQhZY' #BotFather에서 발급받은 Telegram Bot Token 입력

api_key = '8371076bd1820274bab96c5582eb7e41' #OpenWeatherMap에서 발급받은 API Key 입력

bot = Bot(token=my_token) #Telegram Bot 객체 생성

ALERT_HOURS = [7, 10, 13, 16, 19, 22] #3시간 간격으로 알림을 보낼 시간 목록

#추가로 알림을 보낼 사용자 지정 시간
ALERT_TIMES = ["08:30", "14:45"]

def getWeather(): #날씨 정보를 가져와 문자열 형태로 반환하는 함수

     #OpenWeatherMap API 요청 URL
     #q=Seoul → 서울 지역 날씨 요청
    #units=metric → 섭씨 온도 사용
    #lang=en → 영어 설명 사용
    url = f"https://api.openweathermap.org/data/2.5/forecast?q=Seoul&appid={api_key}&units=metric&lang=en"

    #API 서버에 요청 보내기
    with urllib.request.urlopen(url) as r:

        #응답 데이터를 JSON 형태로 변환
        data = json.loads(r.read())

    #최종 출력 문자열 초기화
    text = ""

    #예보 데이터 8개 반복 출력
    for i in range(8):

        #i번째 예보 데이터 가져오기
        item = data['list'][i]

        #날짜/시간 정보에서 시간 추출
        #UTC → 한국시간(KST) 변환 위해 +9 수행
        hour = str((int(item['dt_txt'][11:13]) + 9) % 24).zfill(2)

         #온도 정보 추출
        temp = item['main']['temp']

        #습도 정보 추출
        humi = item['main']['humidity']

        #날씨 설명 정보 추출
        desc = item['weather'][0]['description']

        #문자열 형태로 결과 추가
        text += f"({hour}h {temp}C {humi}% {desc})\n"

    #완성된 문자열 반환
    return text


#비동기 메인 함수 정의
async def main():

    try:

        #무한 반복 실행
        while True:

            #현재 시간 가져오기
            now = datetime.datetime.now()

            #현재 시간을 "시:분" 형식으로 저장
            hm = now.strftime('%H:%M')

            #현재 시간이 정각이며 ALERT_HOURS 목록에 포함된 시간인지 확인
            is_alert_hour = now.hour in ALERT_HOURS and now.minute == 0 and now.second == 0

            #현재 시간이 사용자 지정 시간인지 확인
            is_alert_time = hm in ALERT_TIMES and now.second == 0

            #두 조건 중 하나라도 만족하면 실행
            if is_alert_hour or is_alert_time:

                #날씨 정보 가져오기
                msg = getWeather()

                #터미널에 출력
                print(msg)

                #Telegram으로 메시지 전송
                await bot.send_message(chat_id=telegram_id, text=msg)

            #1초 대기 후 반복
            await asyncio.sleep(1)

    #프로그램 종료
    except KeyboardInterrupt:
        pass


# 비동기 메인 함수 실행
asyncio.run(main())
